local genCorner = Instance.new("UICorner")
genCorner.CornerRadius = UDim.new(0, 24)
genCorner.Parent = generateBtn

generateBtn.MouseButton1Click:Connect(function()
    local url = urlBox.Text:match("^%s*(.-)%s*$")
    if url == "" then
        statusLabel.Text = "Please enter a valid raw URL"
        statusLabel.TextColor3 = Color3.fromRGB(255, 174, 174)
        return
    end
    statusLabel.Text = "Fetching script..."
    statusLabel.TextColor3 = Color3.fromRGB(127, 159, 207)
    
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        local preview = result:sub(1, 500)
        if #result > 500 then preview = preview .. "\n... (truncated)" end
        previewBox.Text = preview
        
        local safeUrl = url:gsub('"', '\\"')
        local loadstringCode = 'loadstring(game:HttpGet("' .. safeUrl .. '"))()'
        outputBox.Text = loadstringCode
        
        statusLabel.Text = "Loadstring ready. Script length: " .. #result .. " chars"
        statusLabel.TextColor3 = Color3.fromRGB(178, 255, 207)
    else
        local safeUrl = url:gsub('"', '\\"')
        local fallbackCode = 'loadstring(game:HttpGet("' .. safeUrl .. '"))()'
        outputBox.Text = fallbackCode
        previewBox.Text = "Could not fetch preview. The URL may be invalid or blocked. Loadstring was still generated."
        statusLabel.Text = "Warning: Preview failed, but loadstring is ready"
        statusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
end)

